{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install",
    "nixpacksConfig": {
      "aptPackages": ["build-essential", "python3", "libsqlite3-dev"]
    }
  },
  "deploy": {
    "startCommand": "node index.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "always",
    "numReplicas": 1,
    "sleepApplication": false,
    "cronSchedule": "0 7 * * *",
    "cronCommand": "node /app/scripts/railway-cron.js",
    "cronTimeout": 300
  }
}
